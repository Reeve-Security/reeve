{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibom.example/schemas/sensitive-data-report-v0.1.0.json",
  "title": "Reeve Sensitive-Data Report v0.1.0",
  "description": "JSON Schema for the separate opt-in sensitive-data report. This artifact is not an AIBOM sidecar. It records conversation/session-store metadata and optional pattern-scan findings without serializing raw conversation content, raw secret values, surrounding text, embeddings, screenshots, searchable indexes, or hashes of secret values.",
  "type": "object",
  "required": [
    "$schema",
    "sensitiveDataReport"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://aibom.example/schemas/sensitive-data-report-v0.1.0.json"
    },
    "sensitiveDataReport": {
      "$ref": "#/$defs/report"
    }
  },
  "$defs": {
    "report": {
      "type": "object",
      "required": [
        "canonicalization",
        "findings",
        "inputs",
        "redaction",
        "reportId",
        "scan",
        "schemaVersion",
        "surfaces"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "inputs": {
                "properties": {
                  "contentPatternScan": {
                    "const": true
                  }
                },
                "required": [
                  "contentPatternScan"
                ]
              }
            },
            "required": [
              "inputs"
            ]
          },
          "then": {
            "properties": {
              "inputs": {
                "properties": {
                  "rulePacks": {
                    "minItems": 1
                  }
                },
                "required": [
                  "rulePacks"
                ]
              }
            }
          }
        }
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "0.1.0"
        },
        "reportId": {
          "type": "string",
          "minLength": 1
        },
        "canonicalization": {
          "type": "string",
          "const": "RFC8785-JCS+reeve-sensitive-data-report-array-order-v0.1"
        },
        "scan": {
          "$ref": "#/$defs/scanMetadata"
        },
        "inputs": {
          "$ref": "#/$defs/scanInputs"
        },
        "redaction": {
          "$ref": "#/$defs/redaction"
        },
        "surfaces": {
          "type": "array",
          "description": "Metadata inventory by agent surface. Sorted by surface, then redacted root.",
          "items": {
            "$ref": "#/$defs/surfaceInventory"
          }
        },
        "findings": {
          "type": "array",
          "description": "Pattern findings. Empty for metadata-only reports and for pattern scans with no matches. Sorted by surface, redacted path, rule id, then finding id.",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "skipped": {
          "type": "array",
          "description": "Conversation files not read during the content scan because a per-file size cap or the cumulative read budget was exceeded. Recorded as auditable telemetry so a skip is never a silent drop. Carries redacted path and size only, never file content. Omitted when nothing was skipped. Sorted by surface, redacted path, then reason.",
          "items": {
            "$ref": "#/$defs/skippedFile"
          }
        },
        "signature": {
          "$ref": "#/$defs/signatureReference"
        }
      }
    },
    "skippedFile": {
      "type": "object",
      "required": [
        "reason",
        "redactedPath",
        "sizeBytes",
        "surface"
      ],
      "additionalProperties": false,
      "properties": {
        "surface": {
          "$ref": "#/$defs/surfaceName"
        },
        "redactedPath": {
          "$ref": "#/$defs/redactedPath"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "reason": {
          "type": "string",
          "enum": [
            "file-too-large",
            "total-budget-exceeded"
          ]
        }
      }
    },
    "scanMetadata": {
      "type": "object",
      "required": [
        "scanId",
        "scanner",
        "timestamp"
      ],
      "additionalProperties": false,
      "properties": {
        "scanId": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "scanner": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "target": {
          "type": "object",
          "required": [
            "description"
          ],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "enum": [
                "host",
                "filesystem",
                "cluster",
                "container",
                "other"
              ]
            }
          }
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scanInputs": {
      "type": "object",
      "required": [
        "customRules",
        "contentPatternScan",
        "metadataInventory",
        "rulePacks",
        "scannerVersion",
        "suppressions"
      ],
      "additionalProperties": false,
      "properties": {
        "metadataInventory": {
          "type": "boolean",
          "const": true,
          "description": "This report exists only when the operator explicitly enabled conversation/session metadata inventory."
        },
        "contentPatternScan": {
          "type": "boolean",
          "description": "True only when the operator enabled the second opt-in for content pattern scanning."
        },
        "scannerVersion": {
          "type": "string",
          "minLength": 1
        },
        "rulePacks": {
          "type": "array",
          "description": "Versioned rule packs used for contentPatternScan=true. Empty for metadata-only reports.",
          "items": {
            "$ref": "#/$defs/rulePackIdentity"
          }
        },
        "customRules": {
          "type": "array",
          "description": "Operator-supplied rule-pack identities. Empty array means none. Identity is recorded for audit reproducibility, not rule content.",
          "items": {
            "$ref": "#/$defs/customRulePackIdentity"
          }
        },
        "suppressions": {
          "type": "array",
          "description": "Operator-supplied suppressions file identities. Empty array means none. Identity is recorded for audit reproducibility, not suppressed secret content.",
          "items": {
            "$ref": "#/$defs/fileIdentity"
          }
        }
      }
    },
    "redaction": {
      "type": "object",
      "required": [
        "mode",
        "pathStrategy"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "default-redacted",
            "explicit-unredacted"
          ]
        },
        "pathStrategy": {
          "type": "string",
          "enum": [
            "user-controlled-segments"
          ]
        },
        "segmentsRedacted": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "username",
              "hostname",
              "project",
              "repository",
              "session",
              "directory"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "surfaceInventory": {
      "type": "object",
      "required": [
        "fileCount",
        "redactedRoot",
        "surface",
        "totalBytes"
      ],
      "additionalProperties": false,
      "properties": {
        "surface": {
          "$ref": "#/$defs/surfaceName"
        },
        "redactedRoot": {
          "$ref": "#/$defs/redactedPath"
        },
        "fileCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalBytes": {
          "type": "integer",
          "minimum": 0
        },
        "oldestModified": {
          "type": "string",
          "format": "date-time"
        },
        "newestModified": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "finding": {
      "type": "object",
      "required": [
        "confidence",
        "evidence",
        "file",
        "findingId",
        "humanReviewRequired",
        "matchCount",
        "patternClass",
        "ruleId",
        "rulePackVersion",
        "surface"
      ],
      "additionalProperties": false,
      "properties": {
        "findingId": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "$ref": "#/$defs/surfaceName"
        },
        "file": {
          "$ref": "#/$defs/fileMetadata"
        },
        "patternClass": {
          "type": "string",
          "description": "Built-in or customer-defined pattern class. Built-in classes include anthropic-api-key, aws-access-key, generic-api-key, jwt, oauth-client-secret, openai-api-key, and stripe-key.",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "rulePackVersion": {
          "type": "string",
          "minLength": 1
        },
        "matchCount": {
          "type": "integer",
          "minimum": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "humanReviewRequired": {
          "type": "boolean",
          "const": true
        },
        "evidence": {
          "$ref": "#/$defs/evidenceReference"
        },
        "suppressed": {
          "type": "boolean"
        },
        "suppressionId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fileMetadata": {
      "type": "object",
      "required": [
        "lastModified",
        "redactedPath",
        "sizeBytes"
      ],
      "additionalProperties": false,
      "properties": {
        "redactedPath": {
          "$ref": "#/$defs/redactedPath"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "lastModified": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidenceReference": {
      "type": "object",
      "required": [
        "id",
        "sourceRef"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signatureReference": {
      "type": "object",
      "required": [
        "bundleRef",
        "digest",
        "payloadType"
      ],
      "additionalProperties": false,
      "properties": {
        "payloadType": {
          "type": "string",
          "const": "application/vnd.in-toto+json"
        },
        "bundleRef": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "rulePackIdentity": {
      "type": "object",
      "required": [
        "digest",
        "id",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "fileIdentity": {
      "type": "object",
      "required": [
        "digest",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "customRulePackIdentity": {
      "type": "object",
      "required": [
        "canonicalId",
        "digest",
        "id",
        "version"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "canonicalId": {
          "type": "string",
          "description": "<rulePackId>@<rulePackVersion>:<sha256-of-rule-content>",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}@[A-Za-z0-9][A-Za-z0-9._+-]{0,63}:[a-f0-9]{64}$"
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    },
    "digest": {
      "type": "object",
      "required": [
        "alg",
        "content"
      ],
      "additionalProperties": false,
      "properties": {
        "alg": {
          "type": "string",
          "const": "SHA-256"
        },
        "content": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "surfaceName": {
      "type": "string",
      "minLength": 1,
      "description": "Agent or assistant surface name, for example claude-desktop, cursor, codex-app, codex-cli, continue, vscode-mcp, zed, factory, or another future surface."
    },
    "redactedPath": {
      "type": "string",
      "minLength": 1,
      "description": "Path with user-controlled segments redacted or anonymized. Raw paths belong only in local investigation, not serialized default reports."
    }
  }
}
