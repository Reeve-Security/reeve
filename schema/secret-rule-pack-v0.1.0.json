{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibom.example/schemas/secret-rule-pack-v0.1.0.json",
  "title": "Reeve Customer Secret Rule Pack v0.1.0",
  "description": "JSON Schema for operator-supplied conversation secret rule packs. Reeve records rule-pack identity and digest in sensitive-data reports, but never serializes rule content or matched values.",
  "type": "object",
  "required": [
    "rulePackId",
    "rulePackVersion",
    "rules"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://aibom.example/schemas/secret-rule-pack-v0.1.0.json"
    },
    "rulePackId": {
      "type": "string",
      "description": "Stable customer rule-pack identifier.",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "rulePackVersion": {
      "type": "string",
      "description": "Customer-managed rule-pack version.",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,63}$"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": [
        "confidence",
        "description",
        "patternClass",
        "regex",
        "ruleId"
      ],
      "additionalProperties": false,
      "properties": {
        "ruleId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,191}$"
        },
        "patternClass": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "regex": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "description": "Rust regex syntax. Look-around, backreferences, and other backtracking-only features are rejected by the scanner loader."
        }
      }
    }
  }
}
