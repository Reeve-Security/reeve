{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aibom.example/schemas/aibom-v0.2.0.json",
  "title": "AIBOM Sidecar v0.2.0",
  "description": "JSON Schema for the AIBOM sidecar document produced by the Reeve project. Defines the AIBOM sidecar document produced by Reeve. Paired with a CycloneDX 1.5 document via externalReferences and distributed in JCS-canonical bytes.",
  "type": "object",
  "required": [
    "$schema",
    "aibom"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://aibom.example/schemas/aibom-v0.2.0.json",
      "description": "Immutable schema identifier. Must match this file's $id exactly. Any mismatch with aibom.schemaVersion produces error aibom.version_mismatch."
    },
    "aibom": {
      "$ref": "#/$defs/aibomBody"
    }
  },
  "$defs": {
    "aibomBody": {
      "type": "object",
      "required": [
        "canonicalization",
        "components",
        "evidence",
        "scan",
        "schemaVersion"
      ],
      "additionalProperties": false,
      "properties": {
        "canonicalization": {
          "type": "string",
          "const": "RFC8785-JCS+aibom-array-order-v0.1",
          "description": "Fixed for v0.1. Identifies the canonicalization profile."
        },
        "schemaVersion": {
          "type": "string",
          "const": "0.2.0",
          "description": "Machine-readable schema version. Must match the version pinned by $schema URL."
        },
        "scan": {
          "$ref": "#/$defs/scanMetadata"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRecord"
          }
        },
        "components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component"
          }
        },
        "policyVerdicts": {
          "type": "array",
          "description": "Policy engine verdicts against the sidecar. Sorted by policy id, then bomRef, then verdict id. Optional at v0.1 because scans may be emitted before policy evaluation runs.",
          "items": {
            "$ref": "#/$defs/policyVerdict"
          }
        }
      }
    },
    "scanMetadata": {
      "type": "object",
      "required": [
        "adapter",
        "scanId",
        "scanner",
        "timestamp"
      ],
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "scanId": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "scanner": {
          "type": "object",
          "description": "Identity of the scanner binary that produced this sidecar (Reeve CLI version, or third-party emitter). Required per SPEC.md scan-metadata definition \u2014 scanner identity is load-bearing for reproducibility and trust context. Distinct from adapter (which names the protocol-adapter plugin).",
          "required": [
            "name",
            "version"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "target": {
          "type": "object",
          "description": "Description of what was scanned (host, cluster, filesystem root). Optional in v0.1.",
          "required": [
            "description"
          ],
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "minLength": 1
            },
            "kind": {
              "type": "string",
              "enum": [
                "host",
                "filesystem",
                "cluster",
                "container",
                "other"
              ]
            }
          }
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Scan duration in milliseconds. Optional."
        }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "reference"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "description": "Closed enum in v0.1. Additions require a schema version bump.",
          "enum": [
            "mcp-registration",
            "mcp-tools-list",
            "mcp-resources-list",
            "mcp-prompts-list",
            "sandbox-syscall",
            "sandbox-network",
            "sandbox-filesystem",
            "sandbox-process",
            "sandbox-mcp-invoke",
            "osv-advisory",
            "sigstore-bundle",
            "rekor-entry",
            "policy-verdict",
            "granted-permission"
          ]
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "component": {
      "type": "object",
      "required": [
        "bom-ref",
        "capabilities",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "bom-ref": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": [
            "built-in",
            "user-defined"
          ],
          "description": "Trust source for the component discovery surface. Built-in means Reeve shipped the surface in the signed binary; user-defined means the surface came from user-supplied configuration and policy may apply stricter rules."
        },
        "capabilities": {
          "type": "object",
          "required": [
            "declared",
            "observed",
            "granted"
          ],
          "additionalProperties": false,
          "properties": {
            "declared": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/capabilityDeclared"
              }
            },
            "observed": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/capabilityObserved"
              }
            },
            "granted": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/capabilityGranted"
              }
            }
          }
        },
        "vulnerabilities": {
          "type": "array",
          "description": "Evidence layer 5. Each entry references a vulnerability by its advisory ID (CVE / GHSA / OSV) with a status. v0.1 schema reserves the field so downstream consumers do not need to re-parse.",
          "items": {
            "$ref": "#/$defs/vulnerabilityRecord"
          }
        },
        "provenance": {
          "$ref": "#/$defs/provenanceRef",
          "description": "Evidence layer 2. the authoritative provenance is the Sigstore bundle that signs the sidecar + CDX pair. This field carries adapter-extracted references into that bundle for indexing convenience; verifier MUST treat the bundle as the source of truth. Reserved in v0.1."
        },
        "transparency": {
          "$ref": "#/$defs/transparencyRef",
          "description": "Evidence layer 3. Rekor log UUID, log URL, inclusion-proof reference. Reserved in v0.1; populated via sigstore-bundle evidence records linked from the sidecar."
        },
        "reputation": {
          "$ref": "#/$defs/reputationRecord",
          "description": "Evidence layer 6. Publisher history, install-base counters. Population deferred to v2+; v0.1 schema reserves the field."
        }
      }
    },
    "vulnerabilityRecord": {
      "type": "object",
      "required": [
        "id",
        "source",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Advisory identifier (e.g., CVE-2026-1234, GHSA-xxxx-xxxx-xxxx, OSV-2026-42)."
        },
        "source": {
          "type": "string",
          "enum": [
            "cve",
            "ghsa",
            "osv",
            "other"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "affected",
            "not-affected",
            "fixed",
            "under-investigation",
            "will-not-fix"
          ]
        },
        "referenceUrl": {
          "type": "string",
          "format": "uri"
        },
        "evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Optional references into the top-level evidence ledger that back the advisory claim (e.g., an osv-advisory evidence record)."
        }
      }
    },
    "provenanceRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "oidcIssuer": {
          "type": "string",
          "format": "uri"
        },
        "oidcSubject": {
          "type": "string",
          "minLength": 1
        },
        "sigstoreCertRef": {
          "type": "string",
          "minLength": 1,
          "description": "Evidence ID pointing to a sigstore-bundle evidence record, or a URI."
        },
        "fulcioChainRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transparencyRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rekorLogUuid": {
          "type": "string",
          "minLength": 1
        },
        "rekorLogUrl": {
          "type": "string",
          "format": "uri"
        },
        "inclusionProofRef": {
          "type": "string",
          "minLength": 1,
          "description": "Evidence ID pointing to a rekor-entry evidence record."
        }
      }
    },
    "reputationRecord": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "publisherIdentifier": {
          "type": "string",
          "minLength": 1
        },
        "publisherFirstSeen": {
          "type": "string",
          "format": "date-time"
        },
        "installBaseCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "policyVerdict": {
      "type": "object",
      "required": [
        "id",
        "policyId",
        "status",
        "justification"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable verdict id. Required for deterministic ordering when a single policy fires multiple verdicts."
        },
        "policyId": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of the policy that produced this verdict (e.g., no-undeclared-egress, signature-required)."
        },
        "bomRef": {
          "type": "string",
          "minLength": 1,
          "description": "Optional bom-ref if the verdict is scoped to a specific component. Absent for sidecar-level verdicts."
        },
        "status": {
          "type": "string",
          "enum": [
            "allow",
            "deny",
            "warn"
          ]
        },
        "justification": {
          "type": "string",
          "minLength": 1
        },
        "references": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "description": "JSON Pointer into the AIBOM or CycloneDX document identifying the fields that drove the verdict."
          }
        },
        "evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "description": "Optional references into the top-level evidence ledger (evidence kind = policy-verdict or other)."
          }
        }
      }
    },
    "capabilityDeclared": {
      "allOf": [
        {
          "$ref": "#/$defs/capability"
        },
        {
          "properties": {
            "source": {
              "const": "declared"
            }
          }
        }
      ]
    },
    "capabilityObserved": {
      "allOf": [
        {
          "$ref": "#/$defs/capability"
        },
        {
          "properties": {
            "source": {
              "const": "observed"
            }
          }
        }
      ]
    },
    "capability": {
      "type": "object",
      "required": [
        "evidence",
        "id",
        "qualifiers",
        "source"
      ],
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "id": {
          "$ref": "#/$defs/capabilityId"
        },
        "qualifiers": {
          "type": "object"
        },
        "source": {
          "type": "string",
          "enum": [
            "declared",
            "observed",
            "granted"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "id": {
                "const": "fs:read"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersFsPath"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "fs:write"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersFsPath"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "net:egress"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersNetEgress"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "net:listen"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersNetListen"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "exec:subprocess"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersExecSubprocess"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "env:read"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersEnvRead"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "secret:read"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersSecretRead"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "ipc:connect"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "qualifiers": {
                "$ref": "#/$defs/qualifiersIpcConnect"
              }
            }
          }
        }
      ]
    },
    "capabilityId": {
      "type": "string",
      "anyOf": [
        {
          "$ref": "#/$defs/coreId"
        },
        {
          "$ref": "#/$defs/adapterId"
        },
        {
          "$ref": "#/$defs/reverseDnsId"
        }
      ]
    },
    "coreId": {
      "type": "string",
      "enum": [
        "fs:read",
        "fs:write",
        "net:egress",
        "net:listen",
        "exec:subprocess",
        "env:read",
        "secret:read",
        "ipc:connect"
      ]
    },
    "adapterId": {
      "type": "string",
      "pattern": "^(mcp):[a-z0-9][a-z0-9:-]*$"
    },
    "reverseDnsId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+:[a-z0-9][a-z0-9:-]*$"
    },
    "qualifiersFsPath": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/",
          "minLength": 1,
          "description": "Absolute POSIX path (must start with '/'), or a path prefix ending in '/'. Prefix matches descendants only (not the directory itself). POSIX only in v0.1; Windows deferred."
        }
      }
    },
    "qualifiersNetEgress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "scheme": {
          "type": "string",
          "enum": [
            "http",
            "https",
            "tcp",
            "udp",
            "tls"
          ]
        }
      }
    },
    "qualifiersNetListen": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "scheme": {
          "type": "string",
          "enum": [
            "http",
            "https",
            "tcp",
            "udp",
            "tls"
          ]
        }
      }
    },
    "qualifiersExecSubprocess": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cmd": {
          "type": "string",
          "minLength": 1
        },
        "argCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "qualifiersEnvRead": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "qualifiersSecretRead": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "qualifiersIpcConnect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "peer": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capabilityGranted": {
      "allOf": [
        {
          "$ref": "#/$defs/capability"
        },
        {
          "properties": {
            "source": {
              "const": "granted"
            }
          }
        }
      ]
    }
  }
}
