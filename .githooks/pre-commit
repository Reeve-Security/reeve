#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "${repo_root}"

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks is required for the private/ boundary hook. Install it first." >&2
  echo "macOS: brew install gitleaks" >&2
  exit 1
fi

exec gitleaks protect --staged --redact --config .gitleaks.toml
